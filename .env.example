# Pooled (app runtime — Vercel / Neon pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/ferme?sslmode=require"

# Direct (migrations Prisma CLI)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/ferme?sslmode=require"

# Auth.js — générer avec : openssl rand -base64 32
AUTH_SECRET="changez-moi-en-production"
AUTH_URL="http://localhost:3000"

# Vercel — AUTH_URL par environnement :
#   Dev     : https://la-ferme-se-rebelle-dev.vercel.app
#   Staging : https://la-ferme-se-rebelle-staging.vercel.app
#   Prod    : https://la-ferme-se-rebelle.vercel.app
# Premier déploiement uniquement : RUN_DB_SEED=true
