# Pooled (app runtime — Vercel / Neon pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/ferme?sslmode=require"

# Direct (migrations Prisma CLI)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/ferme?sslmode=require"

# Auth.js — générer avec : openssl rand -base64 32
AUTH_SECRET="changez-moi-en-production"
AUTH_URL="http://localhost:3000"

# Compte administrateur système
# Non-production (dev/staging/local) : admin@test.local / admin12345678 (seed automatique)
# Production : définir ADMIN_EMAIL + ADMIN_PASSWORD (≥ 16 caractères) puis RUN_DB_SEED=true une fois
ADMIN_EMAIL="admin@test.local"
ADMIN_PASSWORD="changez-moi-en-production-16c"

# Secret optionnel pour la réinitialisation via API (header x-db-reset-secret)
DB_RESET_SECRET=""

# Vercel : définir AUTH_URL=https://votre-app.vercel.app
# Premier déploiement production : RUN_DB_SEED=true + ADMIN_PASSWORD fort
