    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
