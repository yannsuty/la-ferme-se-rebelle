generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  EMPLOYEE
}

enum ParcelType {
  PASTURE
  FIELD
}

enum MilkingSession {
  MORNING
  EVENING
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        FarmMembership[]
  pastures           Pasture[]
  grazingAssignments GrazingAssignment[]

  @@map("farms")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  active         Boolean  @default(true)
  isSystemAdmin  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        FarmMembership[]
  grazingAssignments GrazingAssignment[] @relation("AssignedBy")

  @@map("users")
}

model FarmMembership {
  id        String   @id @default(cuid())
  userId    String
  farmId    String
  role      Role     @default(EMPLOYEE)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([userId, farmId])
  @@index([farmId])
  @@map("farm_memberships")
}

model Pasture {
  id          String     @id @default(cuid())
  farmId      String
  name        String
  type        ParcelType @default(PASTURE)
  description String?
  /// Polygone GeoJSON : { type: "Polygon", coordinates: [[[lng, lat], ...]] }
  geometry    Json
  color       String     @default("#22c55e")
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  farm               Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  grazingAssignments GrazingAssignment[]

  @@index([farmId])
  @@map("pastures")
}

model GrazingAssignment {
  id           String         @id @default(cuid())
  farmId       String
  date         DateTime       @db.Date
  session      MilkingSession
  pastureId    String
  assignedById String
  notes        String?
  createdAt    DateTime       @default(now())

  farm       Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  pasture    Pasture @relation(fields: [pastureId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([farmId, date, session])
  @@index([pastureId])
  @@map("grazing_assignments")
}
